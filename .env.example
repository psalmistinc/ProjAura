# Database
DATABASE_URL=postgresql://user:password@localhost:5432/project_aura
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Auth
NEXTAUTH_SECRET=your-secret-key-min-32-chars-long-here
NEXTAUTH_URL=http://localhost:3000

# NPA Integration
NPA_API_BASE_URL=https://api.npa.gov.gh/v1
NPA_API_KEY=your-npa-api-key
NPA_WEBHOOK_SECRET=your-npa-webhook-secret

# BoG RTGS
RTGS_API_BASE_URL=https://rtgs.bog.gov.gh/v1
RTGS_API_KEY=your-rtgs-api-key

# Hyperledger Fabric
FABRIC_CHANNEL_NAME=UPPF_Claims
FABRIC_CHAINCODE_NAME=claims
FABRIC_MSP_ID=AuraMSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_CA_ENDPOINT=localhost:7054

# App
APP_ENV=development
ENABLE_MOCKS=true
